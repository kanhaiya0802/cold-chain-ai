# Production Environment Configuration
# Copy this to .env and fill in actual values

# === Database ===
# For Cloud SQL (automatic with Cloud Run):
# DATABASE_URL will be set via Cloud Run environment variables

# For local testing with PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/cold_chain_ai

# === JWT & Security ===
JWT_SECRET=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# === Application ===
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# === CORS ===
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://cold-chain-web-xxxxx.run.app

# === AI/ML ===
GOOGLE_API_KEY=your-google-generative-ai-key-here

# === Email (optional for notifications) ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# === Logging ===
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id

# === Caching (optional) ===
REDIS_URL=redis://localhost:6379/0

# === File Storage (optional) ===
GCS_BUCKET_NAME=cold-chain-ai-uploads
GCS_PROJECT_ID=your-gcp-project-id
